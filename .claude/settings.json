{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(*)",
      "Write(*)",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "Agent(*)",
      "WebFetch(*)",
      "WebSearch(*)",
      "NotebookEdit(*)",
      "TodoWrite(*)",
      "mcp__Claude_in_Chrome__*(*)",
      "mcp__Claude_Preview__*(*)",
      "mcp__0ea23958-f42b-4f16-a318-6c2fc4392af0__*(*)",
      "mcp__870f4e09-7600-44a6-9857-2a6088bcede9__*(*)",
      "mcp__97ddc031-d14f-4ac1-bdb5-2d6bbb615c42__*(*)",
      "mcp__ee423be4-962c-4db4-ba0b-d19317a654ed__*(*)",
      "mcp__mcp-registry__*(*)",
      "mcp__scheduled-tasks__*(*)",
      "mcp__c1fc4002-5f49-5f9d-a4e5-93c4ef5d6a75__*(*)",
      "mcp__highlevel__*(*)"
    ],
    "deny": []
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== SESSION START ===' && echo 'Date:' $(date '+%Y-%m-%d %H:%M') && echo '---' && echo 'Token budget: monitor context usage. Compact at 70%.' && echo '---' && cat ~/.claude/ARCHITECTURE_MAP.md 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "echo '=== SESSION END CHECKLIST ===' && echo '[ ] Update brain/ notes with learnings' && echo '[ ] Update work/Index.md if new work' && echo '[ ] Check for orphan notes (no links)' && echo '[ ] Commit changes if needed'"
          }
        ]
      }
    ]
  }
}
