# =============================================================================
# Social Suite configuration. Copy to .env and fill in.
# "FREE" marks credentials available at no cost. Never commit the real .env.
# =============================================================================

# --- Dropbox (ingest) --------------------------------------------------------
# FREE: a Dropbox account + an app created at https://www.dropbox.com/developers/apps
# Short-lived access token, OR use the refresh-token flow (recommended) below.
DROPBOX_ACCESS_TOKEN=
# Refresh-token flow (tokens don't expire; preferred for an always-on watcher):
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=
# Folder to watch for new raw uploads (Dropbox path, e.g. /raw-video).
DROPBOX_WATCH_FOLDER=/raw-video
# Where downloaded raw videos land locally before clipping.
INGEST_DOWNLOAD_DIR=./media/ingest

# --- Clip engine (clip) ------------------------------------------------------
# FREE: ffmpeg is free; transcript-driven highlight selection runs locally.
# Target aspect ratio for shorts (vertical).
CLIP_ASPECT_RATIO=9:16
# Min/max length (seconds) of a generated short.
CLIP_MIN_SECONDS=15
CLIP_MAX_SECONDS=60
# Max number of clips to cut from one source video.
CLIP_MAX_CLIPS=3
# Set to 1 to re-rank highlights with Claude (costs tokens). Default: offline heuristic.
CLIP_USE_LLM=0
CLIP_OUTPUT_DIR=./media/clips

# --- Transcription (caption/transcribe) -------------------------------------
# FREE: faster-whisper / WhisperX run locally; no API key.
# Model size: tiny|base|small|medium|large-v3
WHISPER_MODEL=large-v3
# cpu|cuda
WHISPER_DEVICE=cpu
# Language hint, or "auto".
WHISPER_LANGUAGE=auto

# --- Caption burn-in (caption/burn) -----------------------------------------
# FREE: ffmpeg + libass.
FFMPEG_BINARY=ffmpeg
# Font used for burned captions (must be installed / on fontconfig path).
CAPTION_FONT=Arial
CAPTION_FONT_SIZE=48
# Animation style hook for the renderer: karaoke|popup|word-by-word
CAPTION_STYLE=karaoke
CAPTION_OUTPUT_DIR=./media/captioned

# --- AI copywriting (write) -------------------------------------------------
# PAID: https://console.anthropic.com  (model: claude-opus-4-8)
ANTHROPIC_API_KEY=
# Override only if you must; default is claude-opus-4-8.
ANTHROPIC_MODEL=claude-opus-4-8

# --- Publishing (publish -> Postiz) -----------------------------------------
# FREE: Postiz is open source and self-hostable (https://github.com/gitroomhq/postiz-app).
# Base URL of your Postiz instance (no trailing slash). Public API lives under /public/v1.
POSTIZ_API_URL=https://postiz.example.com
POSTIZ_API_KEY=
# Comma-separated Postiz channel/integration IDs to post to by default.
POSTIZ_DEFAULT_CHANNELS=

# --- Per-platform creds (optional: only for direct posting, bypassing Postiz)
# Most setups post THROUGH Postiz and don't need these. Listed for completeness.
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=

# --- Queue / orchestrator ----------------------------------------------------
# FREE: Redis is open source.
REDIS_URL=redis://localhost:6379/0
# How often (seconds) the orchestrator polls Dropbox for new files.
POLL_INTERVAL_SECONDS=300
# FastAPI bind.
API_HOST=0.0.0.0
API_PORT=8000
