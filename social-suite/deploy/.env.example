# Full-stack deploy config. Copy to .env and fill in. Never commit the real .env.

# --- Public domain + secrets (Postiz / Caddy) --------------------------------
# Subdomain pointed at this server's public IP (DNS A record). No https://, no slash.
DOMAIN=social.yourdomain.com
# openssl rand -hex 32
JWT_SECRET=replace-with-openssl-rand-hex-32
# openssl rand -hex 16
POSTGRES_PASSWORD=replace-with-a-strong-password
# Keep false for first launch (so you can register), then set true + re-run up -d.
DISABLE_REGISTRATION=false

# --- Social suite: AI + ingest -----------------------------------------------
# https://console.anthropic.com  (model: claude-opus-4-8)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Dropbox app (refresh-token flow). https://www.dropbox.com/developers/apps
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=
DROPBOX_REFRESH_TOKEN=
DROPBOX_WATCH_FOLDER=/raw-video

# --- Social suite -> Postiz --------------------------------------------------
# Internal URL is set in the compose (http://postiz:5000); leave API key blank
# until you've connected channels in Postiz, then paste it here and re-run up -d.
POSTIZ_API_KEY=
# Comma-separated Postiz channel IDs to post to (GET /public/v1/integrations).
POSTIZ_DEFAULT_CHANNELS=

# --- Clip / caption tuning (optional) ----------------------------------------
CLIP_MAX_CLIPS=3
CLIP_MIN_SECONDS=15
CLIP_MAX_SECONDS=60
CLIP_USE_LLM=0
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
CAPTION_FONT=Arial
CAPTION_FONT_SIZE=64
