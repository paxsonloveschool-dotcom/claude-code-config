@echo off
REM HP local-timer config for Windows — copy to `config.env.bat` and fill in.
REM `config.env.bat` is git-ignored (machine-specific paths, no secrets).
REM
REM   copy windows\config.env.bat.example windows\config.env.bat
REM   notepad windows\config.env.bat
REM
REM NOTE: the .bat runners look for config.env.bat one level UP (the shared
REM local-timers folder). After editing, MOVE it there:
REM   move windows\config.env.bat ..\config.env.bat
REM (or just keep a copy in both spots).

REM Absolute path to the social-suite folder inside this repo clone.
set "SOCIAL_SUITE_DIR=C:\Users\you\claude-code-config\social-suite"

REM Python launcher (usually "python" on Windows).
set "PYTHON=python"

REM Local, Dropbox-SYNCED folder holding HP's numbered clips for Instagram.
set "IG_FOLDER=C:\Users\you\Dropbox\...\HP Tiktok"

REM Instagram login file (JSON: {"username":"...","password":"..."}).
set "IG_CREDS=%USERPROFILE%\Downloads\ig_creds.json"
