# HP local-timer config — copy this file to `config.env` and fill in for THIS machine.
# `config.env` is git-ignored (it holds machine-specific paths, no secrets).
#
#   cp config.example.env config.env      # (Windows: copy config.example.env config.env)
#   # then edit config.env
#
# ---------------------------------------------------------------------------

# Absolute path to the social-suite folder inside this repo clone.
#   macOS example:   /Users/you/claude-code-config/social-suite
#   Windows example: C:\Users\you\claude-code-config\social-suite
SOCIAL_SUITE_DIR="/absolute/path/to/claude-code-config/social-suite"

# Python launcher. macOS/Linux: usually "python3". Windows: usually "python".
PYTHON="python3"

# Local, Dropbox-SYNCED folder that holds HP's numbered clips (the ones Instagram
# should post). This must be a real folder on this machine that Dropbox keeps
# synced — Instagram's poster reads the video files directly off disk.
#   example: /Users/you/Dropbox/.../Apps/hp-restore-suite-8472/HP Tiktok
IG_FOLDER="/absolute/path/to/Dropbox/.../HP Tiktok"

# Instagram login file (JSON: {"username":"...","password":"..."}).
# Default matches the poster's built-in default; change only if you keep it elsewhere.
IG_CREDS="$HOME/Downloads/ig_creds.json"
