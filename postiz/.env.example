# ─── Postiz configuration ───────────────────────────────────────────
# Copy this file to ".env" and fill in the values below, then run:
#   docker compose up -d
#
#   cp .env.example .env
#
# NEVER commit your real .env (it holds secrets). It is gitignored.

# Your domain pointed at this server's IP via a DNS "A" record.
# e.g. social.hplandscaping.com  — do NOT include https:// or a trailing slash.
DOMAIN=social.yourdomain.com

# Long random secret used to sign login tokens.
# Generate one with:  openssl rand -hex 32
JWT_SECRET=replace-with-openssl-rand-hex-32

# Database password. Generate one with:  openssl rand -hex 16
POSTGRES_PASSWORD=replace-with-a-strong-password

# Keep "false" for first launch so you can register your account.
# Change to "true" and re-run `docker compose up -d` once you're signed up.
DISABLE_REGISTRATION=false

# Container image. Leave commented on normal (amd64/x86) servers.
# On an ARM server (e.g. Oracle Cloud A1), uncomment and pin a published
# arm64 tag — find the newest one here:
#   https://github.com/gitroomhq/postiz-app/pkgs/container/postiz-app
# (filter the tags for "-arm64"). Example:
# POSTIZ_IMAGE=ghcr.io/gitroomhq/postiz-app:v2.21.0-arm64
