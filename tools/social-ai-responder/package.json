{
  "name": "social-ai-responder",
  "version": "1.0.0",
  "private": true,
  "description": "AI auto-responder for Facebook & Instagram DMs and comments, on Cloudflare Workers + Claude.",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "typecheck": "tsc --noEmit",
    "kv:create": "wrangler kv namespace create STATE",
    "secret:appsecret": "wrangler secret put META_APP_SECRET",
    "secret:verify": "wrangler secret put META_VERIFY_TOKEN",
    "secret:pagetoken": "wrangler secret put META_PAGE_TOKEN",
    "secret:anthropic": "wrangler secret put ANTHROPIC_API_KEY",
    "secret:escalation": "wrangler secret put ESCALATION_WEBHOOK_URL",
    "secret:twilio": "wrangler secret put TWILIO_AUTH_TOKEN",
    "secret:twiliosid": "wrangler secret put TWILIO_ACCOUNT_SID",
    "secret:resend": "wrangler secret put RESEND_API_KEY"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.70.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260101.0",
    "typescript": "^5.6.0",
    "wrangler": "^4.0.0"
  }
}
